{
  "permissions": {
    "allow": [
      "Bash(gh pr create:*)",
      "Bash(git push origin ticket/*)",
      "Bash(python tooling/glue/*)",
      "Bash(python -m tooling.verify.run:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git fetch origin:*)",
      "Bash(git merge origin/main:*)",
      "Bash(git merge --abort:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "powershell -NoProfile -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.ps1\"" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "powershell -NoProfile -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-main-push.ps1\"" },
          { "type": "command", "command": "powershell -NoProfile -File \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-db-in-git.ps1\"" }
        ]
      }
    ]
  }
}
