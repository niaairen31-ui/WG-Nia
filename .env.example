# Copy to .env and adjust as needed.
# Database engine URL. Defaults to a local SQLite file when unset.
# SQLite (local phase):
WORLD_ENGINE_DATABASE_URL=sqlite:///world_engine.db
# PostgreSQL / Supabase (later) — only this line changes, no code change:
# WORLD_ENGINE_DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
